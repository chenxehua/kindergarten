<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kgms.data.mapper.SystemConfigMapper">

    <resultMap id="BaseResultMap" type="com.kgms.data.entity.SystemConfig">
        <id column="id" property="id"/>
        <result column="config_id" property="configId"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="config_type" property="configType"/>
        <result column="description" property="description"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_system_config WHERE id = #{id}
    </select>

    <select id="selectByConfigId" resultMap="BaseResultMap">
        SELECT * FROM t_system_config WHERE config_id = #{configId}
    </select>

    <select id="selectByConfigKey" resultMap="BaseResultMap">
        SELECT * FROM t_system_config WHERE config_key = #{configKey}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM t_system_config ORDER BY config_key
    </select>

    <insert id="insert" parameterType="com.kgms.data.entity.SystemConfig" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_system_config (
            config_id, config_key, config_value, config_type, description, is_enabled
        ) VALUES (
            #{configId}, #{configKey}, #{configValue}, #{configType}, #{description}, #{isEnabled}
        )
    </insert>

    <update id="updateByConfigId" parameterType="com.kgms.data.entity.SystemConfig">
        UPDATE t_system_config SET
            config_value = #{configValue},
            config_type = #{configType},
            description = #{description},
            is_enabled = #{isEnabled}
        WHERE config_id = #{configId}
    </update>

    <delete id="deleteByConfigId">
        DELETE FROM t_system_config WHERE config_id = #{configId}
    </delete>
</mapper>
